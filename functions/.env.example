# Cloud Functions 環境変数設定例

# Firebase Functions v2 では .env ファイルがサポートされています
# このファイルを functions/.env にコピーして使用してください

# Spotify API認証情報
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ユーザー並列処理数
DEFAULT_USER_CONCURRENCY=5

# 安全マージン(分)
SAFETY_WINDOW_MINUTES=129600
